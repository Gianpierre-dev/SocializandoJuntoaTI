---
import { getCollection } from "astro:content";
import { site } from "../../data/site";
import SectionHeading from "../ui/section-heading.astro";
import Button from "../ui/button.astro";

const values = (await getCollection("values")).sort(
  (a, b) => a.data.order - b.data.order,
);

const previewValues = values.slice(0, 4);
---

<section class="bg-surface py-16 sm:py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <SectionHeading
      title="Quiénes somos"
      subtitle="Una comunidad que acompaña el bienestar emocional de jóvenes a través de actividades, escucha y crecimiento compartido."
    />

    <div class="mt-12 grid gap-8 md:grid-cols-2">
      {
        site.mission && (
          <div class="rounded-2xl border border-line bg-subtle p-8">
            <h3 class="text-xl font-semibold text-accent">Misión</h3>
            <p class="mt-3 text-base leading-relaxed text-content/80">
              {site.mission}
            </p>
          </div>
        )
      }
      {
        site.vision && (
          <div class="rounded-2xl border border-gold/20 bg-gold/5 p-8">
            <h3 class="text-xl font-semibold text-gold">Visión</h3>
            <p class="mt-3 text-base leading-relaxed text-content/80">
              {site.vision}
            </p>
          </div>
        )
      }
    </div>

    {
      previewValues.length > 0 && (
        <ul class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {previewValues.map((value) => (
            <li class="rounded-xl border border-line bg-surface p-5 shadow-sm">
              <h4 class="font-semibold text-content">{value.data.title}</h4>
              <p class="mt-2 text-sm leading-relaxed text-content/70">
                {value.data.description}
              </p>
            </li>
          ))}
        </ul>
      )
    }

    <div class="mt-10 text-center">
      <Button href="/nosotros" variant="ghost" label="Conoce más sobre nosotros" />
    </div>
  </div>
</section>
