---
// Accesos directos tipo portal institucional: iconografía + enlace a cada programa.
interface QuickLink {
  title: string;
  description: string;
  href: string;
  icon: string; // path data de tabler-icons (stroke)
}

const links: QuickLink[] = [
  {
    title: "Voluntariado",
    description: "Únete al equipo y participa en nuestras áreas de trabajo.",
    href: "/voluntariado",
    icon: "M19.5 12.572l-7.5 7.428l-7.5 -7.428a5 5 0 1 1 7.5 -6.566a5 5 0 1 1 7.5 6.572",
  },
  {
    title: "Actividades",
    description: "Talleres psicoeducativos y dinámicas en parques de Lima.",
    href: "/actividades",
    icon: "M4 5h16M4 5v14a1 1 0 0 0 1 1h14a1 1 0 0 0 1 -1v-14M8 3v4M16 3v4M8 13h3M8 17h5",
  },
  {
    title: "Nosotros",
    description: "Conoce nuestra misión, visión y al equipo directivo.",
    href: "/nosotros",
    icon: "M9 7a4 4 0 1 0 8 0a4 4 0 0 0 -8 0M3 21v-2a4 4 0 0 1 4 -4h4a4 4 0 0 1 4 4v2M16 3.13a4 4 0 0 1 0 7.75",
  },
  {
    title: "Contacto",
    description: "Escríbenos para alianzas, consultas o colaboraciones.",
    href: "/contacto",
    icon: "M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10zM3 7l9 6l9 -6",
  },
];
---

<section class="bg-surface" aria-label="Accesos directos">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <ul
      class="grid grid-cols-1 gap-4 py-10 sm:grid-cols-2 lg:-mt-10 lg:grid-cols-4"
    >
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="group flex h-full flex-col gap-3 rounded-2xl border border-line bg-surface p-6 shadow-sm transition-all hover:-translate-y-1 hover:border-brand/40 hover:shadow-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand"
            >
              <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-subtle text-accent transition-colors group-hover:bg-brand group-hover:text-white">
                <svg
                  class="h-6 w-6"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d={link.icon} />
                </svg>
              </span>
              <span class="text-base font-semibold text-content">
                {link.title}
              </span>
              <span class="text-sm leading-relaxed text-content/70">
                {link.description}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
