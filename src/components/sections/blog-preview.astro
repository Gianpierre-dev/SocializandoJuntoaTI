---
import SectionHeading from "../ui/section-heading.astro";
---

<section class="bg-surface py-16 sm:py-20" aria-label="Blog próximamente">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="opacity-60">
      <SectionHeading
        title="Blog"
        subtitle="Pronto compartiremos historias, recursos y reflexiones sobre salud emocional juvenil."
      />
    </div>

    <div class="mt-10 flex justify-center">
      <span
        class="rounded-full bg-subtle px-6 py-3 text-sm font-semibold text-accent/70"
      >
        Próximamente
      </span>
    </div>
  </div>
</section>
