---
import { getCollection } from "astro:content";
import SectionHeading from "../ui/section-heading.astro";

const allies = (await getCollection("allies")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

{
  allies.length > 0 && (
    <section class="bg-brand/5 py-16 sm:py-20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <SectionHeading
          title="Aliados"
          subtitle="Organizaciones y comunidades que caminan junto a nosotros."
        />

        <ul class="mt-10 flex flex-wrap items-center justify-center gap-4">
          {allies.map((ally) => {
            const content = (
              <span class="block text-center">
                <span class="block font-semibold text-brand-deep">
                  {ally.data.name}
                </span>
                {ally.data.handle && (
                  <span class="block text-sm text-brand-deep/60">
                    {ally.data.handle}
                  </span>
                )}
              </span>
            );

            return (
              <li>
                {ally.data.url ? (
                  <a
                    href={ally.data.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="block rounded-2xl border border-brand/10 bg-white px-6 py-4 shadow-sm transition-shadow hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand"
                  >
                    {content}
                  </a>
                ) : (
                  <div class="rounded-2xl border border-brand/10 bg-white px-6 py-4 shadow-sm">
                    {content}
                  </div>
                )}
              </li>
            );
          })}
        </ul>
      </div>
    </section>
  )
}
