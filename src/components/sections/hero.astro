---
import { Image } from "astro:assets";
import logo from "../../assets/logo.png";
import { site } from "../../data/site";
import Button from "../ui/button.astro";
---

<section
  class="relative overflow-hidden bg-gradient-to-b from-subtle via-subtle to-page"
>
  <div
    class="mx-auto grid max-w-6xl items-center gap-10 px-4 py-16 sm:px-6 md:grid-cols-2 md:py-24"
  >
    <div class="text-center md:text-left">
      <p
        class="text-sm font-semibold uppercase tracking-wide text-accent"
      >
        {site.name}
      </p>
      <h1
        class="mt-4 text-4xl font-bold leading-tight text-content sm:text-5xl"
      >
        {site.slogan || "Construimos espacios de bienestar emocional juvenil"}
      </h1>
      {
        site.mission && (
          <p
            class="mx-auto mt-6 max-w-xl text-base leading-relaxed text-content/70 sm:text-lg md:mx-0"
          >
            {site.mission}
          </p>
        )
      }

      <div
        class="mt-8 flex flex-col items-center gap-3 sm:flex-row md:items-start md:justify-start"
      >
        <Button href="/voluntariado" variant="gold" label="Sé voluntario" />
        <Button
          href="/actividades"
          variant="ghost"
          label="Conoce las actividades"
        />
      </div>
    </div>

    <div class="flex justify-center md:justify-end">
      <div
        class="flex h-56 w-56 items-center justify-center rounded-full bg-white/70 p-8 shadow-lg ring-1 ring-brand/10 sm:h-72 sm:w-72"
      >
        <Image
          src={logo}
          alt={`Logo de ${site.name}`}
          width={288}
          height={288}
          class="h-full w-full object-contain"
        />
      </div>
    </div>
  </div>
</section>
