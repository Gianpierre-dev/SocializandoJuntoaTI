---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import logo from "../../assets/logo.png";
import Button from "../ui/button.astro";

const banners = (await getCollection("banners")).sort(
  (a, b) => a.data.order - b.data.order,
);

// Estilos por variante para banners sin imagen.
const variantClasses = {
  brand: "bg-brand text-white",
  gold: "bg-gold text-brand-deep",
  green: "bg-green text-brand-deep",
} as const;

const kickerClasses = {
  brand: "text-gold",
  gold: "text-brand-deep",
  green: "text-brand-deep",
} as const;

const ctaVariants = {
  brand: "gold",
  gold: "primary",
  green: "primary",
} as const;
---

{
  banners.length > 0 && (
    <section
      class="bg-page py-6"
      aria-roledescription="carrusel"
      aria-label="Banners destacados"
    >
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <div
          id="hero-carousel"
          class="flex snap-x snap-mandatory overflow-x-auto scroll-smooth rounded-xl shadow-md [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
        >
          {banners.map((banner, index) => (
            <div
              class="w-full shrink-0 snap-center"
              role="group"
              aria-roledescription="banner"
              aria-label={`${index + 1} de ${banners.length}`}
            >
              {banner.data.image ? (
                <a
                  href={banner.data.href}
                  class="block focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-brand"
                >
                  <Image
                    src={banner.data.image}
                    alt={banner.data.alt ?? banner.data.title}
                    widths={[640, 1024, 1940]}
                    sizes="(max-width: 1152px) 100vw, 1152px"
                    class="aspect-[10/3] w-full object-cover"
                  />
                </a>
              ) : (
                <div
                  class={`grid h-full items-center gap-6 px-8 py-12 sm:grid-cols-[1fr_auto] sm:px-14 sm:py-16 ${variantClasses[banner.data.variant]}`}
                >
                  <div>
                    <p
                      class={`text-xs font-bold uppercase tracking-widest ${kickerClasses[banner.data.variant]}`}
                    >
                      {banner.data.kicker}
                    </p>
                    <p class="mt-3 text-3xl font-bold leading-tight sm:text-4xl">
                      {banner.data.title}
                    </p>
                    {banner.data.description && (
                      <p class="mt-4 max-w-xl text-sm opacity-90 sm:text-base">
                        {banner.data.description}
                      </p>
                    )}
                  </div>
                  {banner.data.ctaLabel ? (
                    <Button
                      href={banner.data.href}
                      variant={ctaVariants[banner.data.variant]}
                      label={banner.data.ctaLabel}
                    />
                  ) : (
                    <div class="hidden sm:block">
                      <Image
                        src={logo}
                        alt=""
                        width={176}
                        height={176}
                        class="h-44 w-44 object-contain drop-shadow-lg"
                      />
                    </div>
                  )}
                </div>
              )}
            </div>
          ))}
        </div>

        {/* Indicadores */}
        <div class="mt-4 flex justify-center gap-2" role="tablist">
          {banners.map((banner, index) => (
            <button
              type="button"
              class="hero-dot h-3 w-3 rounded-full bg-content/25 transition-colors hover:bg-brand/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand data-[active]:bg-brand"
              data-active={index === 0 ? "" : undefined}
              aria-label={`Ir al banner: ${banner.data.title}`}
            />
          ))}
        </div>
      </div>
    </section>
  )
}

<script>
  const carousel = document.getElementById("hero-carousel");
  const dots = Array.from(
    document.querySelectorAll<HTMLButtonElement>(".hero-dot"),
  );

  if (carousel && dots.length > 0) {
    let index = 0;
    let timer: number | undefined;

    const goTo = (i: number) => {
      index = (i + dots.length) % dots.length;
      carousel.scrollTo({
        left: carousel.clientWidth * index,
        behavior: "smooth",
      });
    };

    const syncDots = () => {
      const current = Math.round(carousel.scrollLeft / carousel.clientWidth);
      dots.forEach((dot, i) => {
        if (i === current) dot.setAttribute("data-active", "");
        else dot.removeAttribute("data-active");
      });
      index = current;
    };

    const startAuto = () => {
      stopAuto();
      // Respeta la preferencia de movimiento reducido.
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches)
        return;
      timer = window.setInterval(() => goTo(index + 1), 6000);
    };

    const stopAuto = () => {
      if (timer) window.clearInterval(timer);
      timer = undefined;
    };

    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => {
        goTo(i);
        startAuto();
      });
    });

    carousel.addEventListener("scroll", () => {
      window.requestAnimationFrame(syncDots);
    });
    carousel.addEventListener("pointerenter", stopAuto);
    carousel.addEventListener("pointerleave", startAuto);
    carousel.addEventListener("focusin", stopAuto);
    carousel.addEventListener("focusout", startAuto);

    startAuto();
  }
</script>
