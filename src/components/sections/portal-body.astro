---
// Cuerpo tipo portal institucional: destacado + notas de prensa a la izquierda,
// mosaico de accesos a programas a la derecha (configurable en src/content/programas).
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { site } from "../../data/site";

const programas = (await getCollection("programas")).sort(
  (a, b) => a.data.order - b.data.order,
);

// Estilos por variante para tiles sin imagen.
const variantClasses = {
  brand: "bg-brand text-white",
  gold: "bg-gold text-brand-deep",
  rose: "bg-rose text-brand-deep",
  green: "bg-green text-brand-deep",
  deep: "bg-brand-deep text-white",
  subtle: "bg-subtle text-accent ring-1 ring-line",
} as const;
---

<section class="bg-page pb-16" aria-label="Programas y noticias">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="grid gap-6 lg:grid-cols-2">
      <!-- Columna izquierda: destacado + notas de prensa -->
      <div class="flex flex-col gap-6">
        <a
          href="/nosotros"
          class="group block rounded-xl bg-subtle p-8 ring-1 ring-line transition-shadow hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand"
        >
          <p class="text-sm font-semibold uppercase tracking-wide text-content/60">
            Nuestra misión
          </p>
          <p class="mt-3 text-2xl font-bold leading-snug text-accent">
            Bienestar y salud mental para adolescentes y jóvenes
          </p>
          <p class="mt-3 line-clamp-3 text-sm leading-relaxed text-content/70">
            {site.mission}
          </p>
          <span
            class="mt-4 inline-block text-sm font-semibold text-accent underline-offset-4 group-hover:underline"
          >
            Conócenos →
          </span>
        </a>

        <!-- Notas de prensa -->
        <div
          class="flex min-h-64 flex-1 flex-col justify-end overflow-hidden rounded-xl bg-gradient-to-br from-brand via-brand-deep to-brand-deep"
        >
          <div class="flex-1 px-8 pt-10">
            <p class="text-4xl font-bold leading-tight text-white/95">
              Historias que
              <span class="text-gold">conectan corazones</span>
            </p>
          </div>
          <div class="bg-black/40 px-8 py-5 backdrop-blur-sm">
            <p class="text-xs font-bold uppercase tracking-widest text-white">
              Notas de prensa
            </p>
            <p class="mt-1 text-sm text-white/80">
              Muy pronto compartiremos nuestras notas, convocatorias e
              historias.
            </p>
          </div>
        </div>
      </div>

      <!-- Columna derecha: mosaico de programas -->
      <ul class="grid grid-cols-2 gap-4">
        {
          programas.map((programa) => (
            <li>
              {programa.data.image ? (
                <a
                  href={programa.data.href}
                  class="block overflow-hidden rounded-xl shadow-sm transition-transform hover:-translate-y-1 hover:shadow-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2"
                >
                  <Image
                    src={programa.data.image}
                    alt={programa.data.alt ?? programa.data.title}
                    widths={[320, 640, 924]}
                    sizes="(max-width: 640px) 50vw, 280px"
                    class="aspect-[3/2] w-full object-cover"
                  />
                </a>
              ) : (
                <a
                  href={programa.data.href}
                  class={`flex aspect-[8/5] flex-col justify-end rounded-xl p-5 shadow-sm transition-transform hover:-translate-y-1 hover:shadow-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 ${variantClasses[programa.data.variant]}`}
                >
                  <span class="text-lg font-bold leading-tight sm:text-xl">
                    {programa.data.title}
                  </span>
                  <span class="mt-1 text-sm font-medium opacity-80">
                    {programa.data.subtitle}
                  </span>
                </a>
              )}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
