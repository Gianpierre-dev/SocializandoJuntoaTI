---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="mx-auto max-w-2xl text-center">
  <h2 class="text-3xl font-bold text-brand-deep sm:text-4xl">
    {title}
  </h2>
  {
    subtitle && (
      <p class="mt-4 text-base leading-relaxed text-brand-deep/70 sm:text-lg">
        {subtitle}
      </p>
    )
  }
</div>
