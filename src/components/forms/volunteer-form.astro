---
import { site } from "../../data/site";

const endpoint = site.volunteerEndpoint ?? "";

const studyYears = ["1° - 3° año", "4° - 5° año", "Ya egresé"];

const volunteerTypes = [
  {
    value: "Líder voluntario(a)",
    description: "Coordina, guía, motiva y toma decisiones junto con el equipo.",
  },
  {
    value: "Voluntario(a)",
    description: "Apoya activamente en las actividades del equipo.",
  },
];

const interestAreas = [
  { value: "Proyectos", description: "Desarrollo de talleres, dinámicas y manualidades." },
  { value: "Marketing", description: "Estrategias para fidelizar al público objetivo." },
  { value: "RR. HH. y Comunicaciones", description: "Gestión del talento y buen clima de equipo." },
  { value: "Capacitación Académica", description: "Grupo de estudio para fortalecer conocimientos." },
  { value: "Relaciones Públicas", description: "Imagen de la organización ante el público." },
  { value: "Logística", description: "Planificación de recursos materiales y humanos." },
  { value: "Otros", description: "Otra área de interés." },
];

const permanence = [
  { value: "3 meses", description: "Experiencias." },
  { value: "6 meses", description: "Experiencias + certificado." },
  { value: "1 año", description: "Experiencias + certificado + ser director(a) de SJAT." },
];

const fieldClass =
  "mt-2 w-full rounded-xl border border-brand/20 bg-white px-4 py-3 text-base text-brand-deep shadow-sm transition-colors placeholder:text-brand-deep/40 focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/40";
const labelClass = "block text-sm font-semibold text-brand-deep";
const legendClass = "text-sm font-semibold text-brand-deep";
const optionClass =
  "flex cursor-pointer items-start gap-3 rounded-xl border border-brand/15 bg-white p-3 transition-colors hover:border-brand/40 has-[:checked]:border-brand has-[:checked]:bg-brand/5";
---

<section id="postular" class="scroll-mt-24 bg-brand/5 py-16 sm:py-20">
  <div class="mx-auto max-w-3xl px-4 sm:px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold text-brand-deep sm:text-4xl">
        Postula como voluntario
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-brand-deep/70">
        Completa el formulario y nos pondremos en contacto contigo. Los campos
        marcados con <span class="text-gold">*</span> son obligatorios.
      </p>
    </div>

    <form
      id="volunteer-form"
      data-endpoint={endpoint}
      novalidate
      class="mt-10 space-y-8 rounded-3xl bg-white p-6 shadow-sm sm:p-10"
    >
      <!-- Honeypot anti-spam: hidden from humans, tempting for bots -->
      <div class="absolute left-[-9999px]" aria-hidden="true">
        <label>No completar este campo
          <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
        </label>
      </div>

      <div class="grid gap-6 sm:grid-cols-2">
        <div class="sm:col-span-2">
          <label class={labelClass} for="fullName">
            Nombres y apellidos completos <span class="text-gold">*</span>
            <span class="block text-xs font-normal text-brand-deep/50">
              Tal como saldrá en tu certificado oficial.
            </span>
          </label>
          <input id="fullName" name="Nombres y Apellidos" type="text" required autocomplete="name" class={fieldClass} />
        </div>

        <div>
          <label class={labelClass} for="whatsapp">
            Número de WhatsApp <span class="text-gold">*</span>
          </label>
          <input id="whatsapp" name="WhatsApp" type="tel" inputmode="tel" required autocomplete="tel" class={fieldClass} />
        </div>

        <div>
          <label class={labelClass} for="age">
            Edad <span class="text-gold">*</span>
          </label>
          <input id="age" name="Edad" type="number" min="18" max="35" required class={fieldClass} />
        </div>

        <div>
          <label class={labelClass} for="district">
            Distrito <span class="text-gold">*</span>
          </label>
          <input id="district" name="Distrito" type="text" required class={fieldClass} />
        </div>

        <div>
          <label class={labelClass} for="career">
            Carrera - Universidad o instituto <span class="text-gold">*</span>
            <span class="block text-xs font-normal text-brand-deep/50">
              Ej.: Medicina - UNMSM
            </span>
          </label>
          <input id="career" name="Carrera y Universidad" type="text" required class={fieldClass} />
        </div>
      </div>

      <fieldset>
        <legend class={legendClass}>
          Año de estudio que cursas <span class="text-gold">*</span>
        </legend>
        <div class="mt-3 grid gap-2 sm:grid-cols-3">
          {
            studyYears.map((year) => (
              <label class={optionClass}>
                <input type="radio" name="Año de estudio" value={year} required class="mt-1 accent-brand" />
                <span class="text-sm text-brand-deep">{year}</span>
              </label>
            ))
          }
        </div>
      </fieldset>

      <fieldset>
        <legend class={legendClass}>
          ¿Qué tipo de voluntariado eliges? <span class="text-gold">*</span>
        </legend>
        <div class="mt-3 grid gap-2">
          {
            volunteerTypes.map((type) => (
              <label class={optionClass}>
                <input type="radio" name="Tipo de voluntariado" value={type.value} required class="mt-1 accent-brand" />
                <span class="text-sm">
                  <span class="font-semibold text-brand-deep">{type.value}</span>
                  <span class="block text-brand-deep/60">{type.description}</span>
                </span>
              </label>
            ))
          }
        </div>
      </fieldset>

      <div>
        <label class={labelClass} for="motivation">
          ¿Qué te motiva a formar parte del equipo? <span class="text-gold">*</span>
        </label>
        <textarea id="motivation" name="Motivación" rows="3" required class={fieldClass}></textarea>
      </div>

      <fieldset>
        <legend class={legendClass}>
          Áreas de interés <span class="text-gold">*</span>
          <span class="block text-xs font-normal text-brand-deep/50">
            Elige al menos una.
          </span>
        </legend>
        <div class="mt-3 grid gap-2 sm:grid-cols-2">
          {
            interestAreas.map((area) => (
              <label class={optionClass}>
                <input type="checkbox" name="Áreas de interés" value={area.value} class="mt-1 accent-brand" data-area />
                <span class="text-sm">
                  <span class="font-semibold text-brand-deep">{area.value}</span>
                  <span class="block text-brand-deep/60">{area.description}</span>
                </span>
              </label>
            ))
          }
        </div>
        <p id="areas-error" class="mt-2 hidden text-sm text-red-600" role="alert">
          Selecciona al menos un área de interés.
        </p>
      </fieldset>

      <div>
        <label class={labelClass} for="experience">
          Tu experiencia y aprendizajes previos <span class="text-gold">*</span>
          <span class="block text-xs font-normal text-brand-deep/50">
            En otras organizaciones, voluntariados, prácticas, etc.
          </span>
        </label>
        <textarea id="experience" name="Experiencia previa" rows="3" required class={fieldClass}></textarea>
      </div>

      <fieldset>
        <legend class={legendClass}>
          ¿Cuánto tiempo deseas estar con nosotros? <span class="text-gold">*</span>
        </legend>
        <div class="mt-3 grid gap-2 sm:grid-cols-3">
          {
            permanence.map((option) => (
              <label class={optionClass}>
                <input type="radio" name="Tiempo de permanencia" value={option.value} required class="mt-1 accent-brand" />
                <span class="text-sm">
                  <span class="font-semibold text-brand-deep">{option.value}</span>
                  <span class="block text-brand-deep/60">{option.description}</span>
                </span>
              </label>
            ))
          }
        </div>
      </fieldset>

      <div>
        <label class={labelClass} for="expectations">
          Tus expectativas y compromiso para este año <span class="text-gold">*</span>
        </label>
        <textarea id="expectations" name="Expectativas" rows="3" required class={fieldClass}></textarea>
      </div>

      <div>
        <label class={labelClass} for="finalMessage">
          ¿Algún mensaje final? <span class="text-xs font-normal text-brand-deep/50">(opcional)</span>
        </label>
        <textarea id="finalMessage" name="Mensaje final" rows="2" class={fieldClass}></textarea>
      </div>

      <div class="space-y-4">
        <p
          id="form-status"
          class="hidden rounded-xl px-4 py-3 text-sm"
          role="status"
          aria-live="polite"
        >
        </p>

        <button
          type="submit"
          id="submit-button"
          class="inline-flex w-full items-center justify-center rounded-full bg-brand px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-brand-deep focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-60 sm:w-auto"
        >
          Enviar postulación
        </button>
      </div>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById("volunteer-form") as HTMLFormElement | null;
  const status = document.getElementById("form-status");
  const submitButton = document.getElementById("submit-button") as HTMLButtonElement | null;
  const areasError = document.getElementById("areas-error");

  if (form && status && submitButton) {
    const endpoint = form.dataset.endpoint ?? "";

    const showStatus = (message: string, kind: "success" | "error") => {
      status.textContent = message;
      status.className =
        kind === "success"
          ? "rounded-xl bg-green/10 px-4 py-3 text-sm text-green"
          : "rounded-xl bg-red-50 px-4 py-3 text-sm text-red-700";
    };

    const validateAreas = () => {
      const checked = form.querySelectorAll<HTMLInputElement>("input[data-area]:checked");
      const hasOne = checked.length > 0;
      areasError?.classList.toggle("hidden", hasOne);
      return hasOne;
    };

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      // Honeypot: if a bot filled the hidden field, fake success and stop.
      const honeypot = form.querySelector<HTMLInputElement>('input[name="_gotcha"]');
      if (honeypot && honeypot.value.trim() !== "") {
        showStatus("¡Gracias! Recibimos tu postulación.", "success");
        form.reset();
        return;
      }

      const nativeValid = form.checkValidity();
      const areasValid = validateAreas();

      if (!nativeValid) {
        form.reportValidity();
        return;
      }
      if (!areasValid) {
        areasError?.scrollIntoView({ behavior: "smooth", block: "center" });
        return;
      }

      if (!endpoint) {
        showStatus(
          "El formulario aún no está configurado. Vuelve a intentarlo más tarde.",
          "error",
        );
        return;
      }

      // Build payload: collapse the multiple "Áreas de interés" values into one field.
      const formData = new FormData(form);
      const params = new URLSearchParams();
      const areas: string[] = [];
      for (const [key, value] of formData.entries()) {
        if (key === "_gotcha") continue;
        if (key === "Áreas de interés") {
          areas.push(String(value));
          continue;
        }
        params.append(key, String(value));
      }
      if (areas.length > 0) params.append("Áreas de interés", areas.join("; "));
      params.append("formType", "voluntarios");

      submitButton.disabled = true;
      submitButton.textContent = "Enviando…";
      status.classList.add("hidden");

      try {
        await fetch(endpoint, {
          method: "POST",
          mode: "no-cors",
          headers: { "Content-Type": "application/x-www-form-urlencoded" },
          body: params.toString(),
        });
        // no-cors responses are opaque, so we confirm optimistically.
        form.reset();
        showStatus(
          "¡Gracias! Recibimos tu postulación. Pronto nos pondremos en contacto contigo.",
          "success",
        );
        status.scrollIntoView({ behavior: "smooth", block: "center" });
      } catch (error) {
        showStatus(
          "No pudimos enviar tu postulación. Revisa tu conexión e inténtalo de nuevo.",
          "error",
        );
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = "Enviar postulación";
      }
    });
  }
</script>
