---
import { Image } from "astro:assets";
import logo from "../../assets/logo.png";
import { site } from "../../data/site";
import Button from "../ui/button.astro";

const navLinks = [
  { label: "Inicio", href: "/" },
  { label: "Nosotros", href: "/nosotros" },
  { label: "Actividades", href: "/actividades" },
  { label: "Voluntariado", href: "/voluntariado" },
  { label: "Contacto", href: "/contacto" },
];

const currentPath = Astro.url.pathname;

const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);

const toggleClass =
  "inline-flex h-10 w-10 items-center justify-center rounded-lg text-content/80 transition-colors hover:bg-subtle hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand";
---

<!-- Barra superior institucional -->
<div class="bg-brand-deep text-white">
  <div
    class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-1.5 text-xs sm:px-6"
  >
    <p class="truncate font-medium tracking-wide">
      Organización juvenil de salud mental · Lima, Perú
    </p>
    <div class="flex shrink-0 items-center gap-3">
      <a
        href={site.socials.instagram}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded transition-opacity hover:opacity-80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white"
        aria-label="Instagram"
      >
        <svg
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="4" y="4" width="16" height="16" rx="4"></rect>
          <circle cx="12" cy="12" r="3"></circle>
          <line x1="16.5" y1="7.5" x2="16.5" y2="7.501"></line>
        </svg>
      </a>
      <a
        href={site.socials.linktree}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded font-semibold underline-offset-2 transition-opacity hover:underline hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white"
      >
        Todos nuestros enlaces
      </a>
    </div>
  </div>
</div>

<header
  class="sticky top-0 z-50 border-b border-line bg-surface/90 backdrop-blur"
>
  <div
    class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6"
  >
    <a
      href="/"
      class="flex items-center gap-3 rounded-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand"
      aria-label={`${site.name} - Inicio`}
    >
      <Image
        src={logo}
        alt={`Logo de ${site.name}`}
        width={48}
        height={48}
        class="h-12 w-12 object-contain"
      />
      <span class="hidden text-base font-semibold text-content sm:inline">
        {site.name}
      </span>
    </a>

    <!-- Desktop navigation -->
    <nav class="hidden md:block" aria-label="Navegación principal">
      <ul class="flex items-center gap-6">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                aria-current={isActive(link.href) ? "page" : undefined}
                class={`rounded text-sm font-medium transition-colors hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand ${
                  isActive(link.href) ? "text-accent" : "text-content/80"
                }`}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex items-center gap-2">
      <!-- Theme toggle (always visible) -->
      <button
        id="theme-toggle"
        type="button"
        class={toggleClass}
        aria-label="Cambiar entre tema claro y oscuro"
      >
        <!-- Moon: shown in light mode (click to go dark) -->
        <svg
          class="h-5 w-5 dark:hidden"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
        <!-- Sun: shown in dark mode (click to go light) -->
        <svg
          class="hidden h-5 w-5 dark:block"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path
            d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
          ></path>
        </svg>
      </button>

      <div class="hidden md:block">
        <Button href="/voluntariado" variant="gold" label="Únete" />
      </div>

      <!-- Mobile menu (accessible details/summary disclosure) -->
      <details class="group relative md:hidden">
        <summary
          class="flex cursor-pointer list-none items-center rounded-lg p-2 text-content focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand [&::-webkit-details-marker]:hidden"
          aria-label="Abrir menú de navegación"
        >
          <svg
            class="h-7 w-7 group-open:hidden"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
          <svg
            class="hidden h-7 w-7 group-open:block"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <line x1="6" y1="6" x2="18" y2="18"></line>
            <line x1="6" y1="18" x2="18" y2="6"></line>
          </svg>
        </summary>

        <nav
          class="absolute right-0 top-full mt-2 w-56 rounded-2xl border border-line bg-surface p-2 shadow-lg"
          aria-label="Navegación principal móvil"
        >
          <ul class="flex flex-col">
            {
              navLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    aria-current={isActive(link.href) ? "page" : undefined}
                    class={`block rounded-lg px-4 py-2.5 text-sm font-medium transition-colors hover:bg-subtle focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand ${
                      isActive(link.href) ? "text-accent" : "text-content/80"
                    }`}
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
            <li class="mt-1 px-2 pb-1 pt-2">
              <Button href="/voluntariado" variant="gold" label="Únete" />
            </li>
          </ul>
        </nav>
      </details>
    </div>
  </div>
</header>

<script>
  document
    .getElementById("theme-toggle")
    ?.addEventListener("click", () => {
      const isDark = document.documentElement.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    });
</script>
