---
import { Image } from "astro:assets";
import logo from "../../assets/logo.png";
import { site } from "../../data/site";
import Button from "../ui/button.astro";

const navLinks = [
  { label: "Inicio", href: "/" },
  { label: "Nosotros", href: "/nosotros" },
  { label: "Actividades", href: "/actividades" },
  { label: "Voluntariado", href: "/voluntariado" },
  { label: "Contacto", href: "/contacto" },
];

const currentPath = Astro.url.pathname;

const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<header
  class="sticky top-0 z-50 border-b border-brand/10 bg-white/90 backdrop-blur"
>
  <div
    class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6"
  >
    <a
      href="/"
      class="flex items-center gap-3 rounded-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand"
      aria-label={`${site.name} - Inicio`}
    >
      <Image
        src={logo}
        alt={`Logo de ${site.name}`}
        width={48}
        height={48}
        class="h-12 w-12 object-contain"
      />
      <span class="hidden text-base font-semibold text-brand-deep sm:inline">
        {site.name}
      </span>
    </a>

    <!-- Desktop navigation -->
    <nav class="hidden md:block" aria-label="Navegación principal">
      <ul class="flex items-center gap-6">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                aria-current={isActive(link.href) ? "page" : undefined}
                class={`rounded text-sm font-medium transition-colors hover:text-brand focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand ${
                  isActive(link.href)
                    ? "text-brand"
                    : "text-brand-deep/80"
                }`}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="hidden md:block">
      <Button href="/voluntariado" variant="gold" label="Únete" />
    </div>

    <!-- Mobile menu (accessible details/summary disclosure) -->
    <details class="group relative md:hidden">
      <summary
        class="flex cursor-pointer list-none items-center rounded-lg p-2 text-brand-deep focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand [&::-webkit-details-marker]:hidden"
        aria-label="Abrir menú de navegación"
      >
        <svg
          class="h-7 w-7 group-open:hidden"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <svg
          class="hidden h-7 w-7 group-open:block"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <line x1="6" y1="6" x2="18" y2="18"></line>
          <line x1="6" y1="18" x2="18" y2="6"></line>
        </svg>
      </summary>

      <nav
        class="absolute right-0 top-full mt-2 w-56 rounded-2xl border border-brand/10 bg-white p-2 shadow-lg"
        aria-label="Navegación principal móvil"
      >
        <ul class="flex flex-col">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  aria-current={isActive(link.href) ? "page" : undefined}
                  class={`block rounded-lg px-4 py-2.5 text-sm font-medium transition-colors hover:bg-brand/5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand ${
                    isActive(link.href)
                      ? "text-brand"
                      : "text-brand-deep/80"
                  }`}
                >
                  {link.label}
                </a>
              </li>
            ))
          }
          <li class="mt-1 px-2 pb-1 pt-2">
            <Button href="/voluntariado" variant="gold" label="Únete" />
          </li>
        </ul>
      </nav>
    </details>
  </div>
</header>
