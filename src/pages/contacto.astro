---
import BaseLayout from "../layouts/base-layout.astro";
import SectionHeading from "../components/ui/section-heading.astro";
import Button from "../components/ui/button.astro";
import { site } from "../data/site";

// Real social channels. We replace the single Linktree link by listing each
// channel directly, and keep only those with a configured URL.
const socialChannels = [
  {
    label: "Instagram",
    description: "Novedades, talleres y nuestra comunidad en imágenes.",
    href: site.socials.instagram,
  },
  {
    label: "TikTok",
    description: "Contenido dinámico sobre salud mental para jóvenes.",
    href: site.socials.tiktok,
  },
  {
    label: "Facebook",
    description: "Eventos, anuncios y enlaces con nuestros aliados.",
    href: site.socials.facebook,
  },
].filter((channel) => channel.href && channel.href !== "#");

const hasWhatsApp = Boolean(site.socials.whatsapp && site.socials.whatsapp !== "#");

const pageTitle = `Contacto | ${site.name}`;
const pageDescription = `Escríbenos por WhatsApp o síguenos en nuestras redes. Conoce nuestras sedes presenciales y modalidades en línea de ${site.name}.`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <!-- Intro -->
  <section class="bg-brand-deep py-16 text-white sm:py-20">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <h1 class="text-4xl font-bold sm:text-5xl">Contacto</h1>
      <p class="mt-5 text-base leading-relaxed text-white/80 sm:text-lg">
        Estamos para escucharte. Escríbenos por WhatsApp, síguenos en nuestras
        redes o visítanos en alguna de nuestras sedes presenciales.
      </p>
    </div>
  </section>

  <!-- WhatsApp + Social channels -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <SectionHeading
        title="Hablemos"
        subtitle="Elige el canal que prefieras para ponerte en contacto con nosotros."
      />

      <div class="mx-auto mt-12 grid max-w-5xl gap-6 md:grid-cols-2">
        <!-- WhatsApp highlight -->
        <article
          class="flex flex-col rounded-2xl border border-green/30 bg-green/5 p-8"
        >
          <h2 class="text-2xl font-bold text-brand-deep">WhatsApp</h2>
          <p class="mt-3 flex-1 text-base leading-relaxed text-brand-deep/70">
            La forma más rápida de comunicarte con nuestro equipo. Resolvemos
            tus dudas sobre actividades, voluntariado y alianzas.
          </p>
          {
            hasWhatsApp ? (
              <div class="mt-6">
                <Button
                  href={site.socials.whatsapp}
                  variant="primary"
                  label="Escribir por WhatsApp"
                />
              </div>
            ) : (
              <p class="mt-6 text-sm font-medium text-brand-deep/60">
                Pronto habilitaremos nuestro WhatsApp. Mientras tanto,
                escríbenos por redes sociales.
              </p>
            )
          }
        </article>

        <!-- Social channels -->
        <article class="flex flex-col rounded-2xl border border-brand/15 p-8">
          <h2 class="text-2xl font-bold text-brand-deep">Redes sociales</h2>
          <p class="mt-3 text-base leading-relaxed text-brand-deep/70">
            Síguenos para conocer nuestras actividades y contenidos sobre salud
            mental.
          </p>
          {
            socialChannels.length > 0 ? (
              <ul class="mt-6 space-y-3">
                {socialChannels.map((channel) => (
                  <li>
                    <a
                      href={channel.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="group flex items-start gap-3 rounded-xl border border-transparent p-3 transition-colors hover:border-brand/20 hover:bg-brand/5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand"
                    >
                      <span class="font-semibold text-brand group-hover:text-brand-deep">
                        {channel.label}
                      </span>
                      <span class="text-sm text-brand-deep/70">
                        {channel.description}
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="mt-6 text-sm font-medium text-brand-deep/60">
                Estamos preparando nuestras redes. Vuelve pronto.
              </p>
            )
          }
        </article>
      </div>
    </div>
  </section>

  <!-- Locations + online modalities -->
  <section class="bg-brand/5 py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <SectionHeading
        title="Dónde nos encuentras"
        subtitle="Realizamos actividades de forma presencial en distintos parques de Lima y también en línea."
      />

      <div class="mx-auto mt-12 grid max-w-5xl gap-6 md:grid-cols-2">
        <!-- Presential locations -->
        <article class="rounded-2xl border border-brand/15 bg-white p-8">
          <h2 class="text-2xl font-bold text-brand-deep">Sedes presenciales</h2>
          <p class="mt-3 text-base leading-relaxed text-brand-deep/70">
            Nos reunimos en estos espacios abiertos de la ciudad.
          </p>
          {
            site.locations.length > 0 && (
              <ul class="mt-6 space-y-3">
                {site.locations.map((location) => (
                  <li class="flex items-center gap-3 text-base text-brand-deep">
                    <span
                      class="h-2.5 w-2.5 shrink-0 rounded-full bg-rose"
                      aria-hidden="true"
                    />
                    {location}
                  </li>
                ))}
              </ul>
            )
          }
        </article>

        <!-- Online modalities -->
        <article class="rounded-2xl border border-brand/15 bg-white p-8">
          <h2 class="text-2xl font-bold text-brand-deep">Modalidad en línea</h2>
          <p class="mt-3 text-base leading-relaxed text-brand-deep/70">
            También participamos a distancia a través de estas plataformas.
          </p>
          {
            site.online.length > 0 && (
              <ul class="mt-6 space-y-3">
                {site.online.map((platform) => (
                  <li class="flex items-center gap-3 text-base text-brand-deep">
                    <span
                      class="h-2.5 w-2.5 shrink-0 rounded-full bg-green"
                      aria-hidden="true"
                    />
                    {platform}
                  </li>
                ))}
              </ul>
            )
          }
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
