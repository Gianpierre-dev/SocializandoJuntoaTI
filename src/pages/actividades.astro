---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/base-layout.astro";
import SectionHeading from "../components/ui/section-heading.astro";
import VolunteerCta from "../components/sections/volunteer-cta.astro";

const activities = (await getCollection("activities")).sort(
  (a, b) => a.data.order - b.data.order,
);

const modalityLabels: Record<"presencial" | "online" | "mixto", string> = {
  presencial: "Presencial",
  online: "En línea",
  mixto: "Mixto",
};

const pageTitle = "Actividades | Socializando Junto A Ti";
const pageDescription =
  "Conoce en detalle nuestras actividades: picnics sociales, talleres y conversatorios en línea, gincanas, voluntariados y más espacios para cuidar tu salud mental.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <SectionHeading
        title="Nuestras actividades"
        subtitle="Espacios pensados para conectar, aprender y cuidar la salud emocional de adolescentes y jóvenes."
      />

      {
        activities.length > 0 ? (
          <ul class="mt-12 grid list-none gap-6 p-0 sm:grid-cols-2">
            {activities.map((activity) => {
              const isComingSoon = activity.data.status === "in-development";
              return (
                <li>
                  <article
                    class={`flex h-full flex-col rounded-2xl border border-line bg-surface p-6 shadow-sm transition-shadow duration-200 hover:shadow-md sm:p-8 ${
                      isComingSoon ? "opacity-70" : ""
                    }`}
                  >
                    <div class="mb-3 flex flex-wrap items-center gap-2">
                      <span class="rounded-full bg-green/15 px-3 py-1 text-xs font-semibold text-green">
                        {modalityLabels[activity.data.modality]}
                      </span>
                      {isComingSoon && (
                        <span class="rounded-full bg-gold/15 px-3 py-1 text-xs font-semibold text-gold">
                          Próximamente
                        </span>
                      )}
                    </div>

                    <h3 class="text-xl font-semibold text-content">
                      {activity.data.title}
                    </h3>

                    <p class="mt-3 flex-1 text-sm leading-relaxed text-content/70">
                      {activity.data.description}
                    </p>

                    <p class="mt-6 border-t border-line pt-4 text-sm font-medium text-accent">
                      <span class="text-content/50">Costo:</span>{" "}
                      {activity.data.cost}
                    </p>
                  </article>
                </li>
              );
            })}
          </ul>
        ) : (
          <p class="mt-12 text-center text-content/60">
            Pronto publicaremos nuestras actividades.
          </p>
        )
      }
    </div>
  </section>

  <VolunteerCta />
</BaseLayout>
