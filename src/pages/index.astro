---
import BaseLayout from "../layouts/base-layout.astro";
import { site } from "../data/site";
import Hero from "../components/sections/hero.astro";
import PortalBody from "../components/sections/portal-body.astro";
import AboutPreview from "../components/sections/about-preview.astro";
import ActivitiesGrid from "../components/sections/activities-grid.astro";
import TeamGrid from "../components/sections/team-grid.astro";
import AlliesStrip from "../components/sections/allies-strip.astro";
import VolunteerCta from "../components/sections/volunteer-cta.astro";
import BlogPreview from "../components/sections/blog-preview.astro";

const title = `${site.name} | ${site.slogan}`;
const description = site.objective;
---

<BaseLayout title={title} description={description}>
  <Hero />
  <PortalBody />
  <AboutPreview />
  <ActivitiesGrid limit={6} />
  <TeamGrid />
  <AlliesStrip />
  <VolunteerCta />
  <BlogPreview />
</BaseLayout>
