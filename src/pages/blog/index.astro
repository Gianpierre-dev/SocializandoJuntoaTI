---
import BaseLayout from "../../layouts/base-layout.astro";
import BlogPreview from "../../components/sections/blog-preview.astro";
import Button from "../../components/ui/button.astro";
import { site } from "../../data/site";

const title = `Blog | ${site.name}`;
const description =
  "Muy pronto compartiremos historias, recursos y reflexiones sobre salud emocional juvenil. Nuestro blog está en desarrollo para la Etapa 2.";
---

<BaseLayout title={title} description={description}>
  <BlogPreview />

  <section class="bg-white pb-20 text-center" aria-label="Volver al inicio">
    <div class="mx-auto max-w-2xl px-4 sm:px-6">
      <p class="text-base leading-relaxed text-brand-deep/70">
        Mientras preparamos nuestro blog, conoce nuestras actividades y cómo
        puedes ser parte de la comunidad.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <Button href="/actividades" variant="primary" label="Ver actividades" />
        <Button href="/" variant="ghost" label="Volver al inicio" />
      </div>
    </div>
  </section>
</BaseLayout>
